# Rally Web — Environment Variables
# Copy to .env.local and fill in values. NEVER commit .env.local.

# Firebase Client (NEXT_PUBLIC_)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (server-only)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Cloudflare (scoped token — DNS:Edit on rally.vin only)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
# Optional — only needed if any code path falls back to legacy email+key auth.
CLOUDFLARE_EMAIL=

# Plesk (subdomain vhost provisioning)
PLESK_API_URL=
PLESK_API_KEY=

# VPS
VPS_IP=

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=
# Server-side Mapbox calls (geocoding from API routes). Same token, different
# variable name — Next.js server runtime cannot read NEXT_PUBLIC_* securely.
MAPBOX_TOKEN=

# Rally VPS API (same box — use localhost in production)
RALLY_API_URL=http://127.0.0.1:8080
RALLY_API_KEY=

# External APIs
VINCUE_API_KEY=
KAHU_API_KEY=
GHOST_API_KEY=

# Integration health probe base URLs (defaults baked into route — override
# here only if the upstream changes). Used by /api/admin/integrations/health.
VINCUE_API_BASE=https://pro.vincue.com/api
DRIVECENTRIC_API_BASE=https://core.drivecentric.io
KAHU_API_BASE=https://kdw-next.kahuapp.com
GHOST_API_BASE=https://aicdjr.com/fleet/dev/v1
# eLead has no known unauthenticated health endpoint. Set this if/when one
# becomes available; otherwise the integration shows as "Not Configured".
ELEAD_HEALTH_URL=

# AI (Anthropic — Claude Sonnet)
ANTHROPIC_API_KEY=

# Stripe — billing (test mode keys start with sk_test_/pk_test_)
# Swap to sk_live_/pk_live_ when ready to charge real money. No code change needed.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Cross-portal hosts (used by impersonation handoff in @rally/ui).
# Defaults are baked into ImpersonationHandoff.tsx; set these only if the
# subdomain mapping changes (e.g. for staging environments).
NEXT_PUBLIC_ADMIN_HOST=https://admin.rally.vin
NEXT_PUBLIC_STAFF_HOST=https://app.rally.vin
NEXT_PUBLIC_MANAGE_HOST=https://manage.rally.vin

# Apple Wallet (PassKit) — required for /api/cards/wallet to mint .pkpass
# files. Until these are set, the route returns 501 with a setup hint and
# the cards page surfaces the error to the user via Toast. Either provide
# cert/key/WWDR contents inline (PEM strings) OR a path on disk relative to
# the app cwd or absolute. The route checks ENV first then falls back to
# disk lookups under apps/staff/certs/ and /etc/rally/certs/.
APPLE_PASS_TYPE_IDENTIFIER=
APPLE_TEAM_IDENTIFIER=
APPLE_PASS_SIGNER_CERT=
APPLE_PASS_SIGNER_CERT_PATH=
APPLE_PASS_SIGNER_KEY=
APPLE_PASS_SIGNER_KEY_PATH=
APPLE_PASS_SIGNER_KEY_PASSPHRASE=
APPLE_PASS_WWDR=
APPLE_PASS_WWDR_PATH=

# Access Control
SUPER_ADMIN_UIDS=
