rules_version = '2';

// ============================================================================
// Firestore Security Rules — guess-63e3d
// ============================================================================
//
// This file covers TWO products that share this Firebase project:
//   1. Rally (rally.vin) — automotive dealership operating system
//      Rally roles: owner, general_manager, sales_manager, service_manager,
//        finance_manager, desk_manager, salesperson, bdc_agent,
//        service_advisor, technician, porter, detailer, parts
//      Rally collections: dealerships/, vehicleLists/, vehicleActivities/,
//        nfcTags/, interactions/, testDrives/, parkingSpaces/, alerts/,
//        crmCustomers/, fleetVehicles/, batteryReports/, recentCrmViews/,
//        auditLogs/, aiUsage/, featureFlags/, system/, employees/,
//        groups/{id}/stores/, groups/{id}/config, groups/{id}/roles
//
//   2. Guess / WalletCard (legacy) — multi-tenant SaaS over the same project
//      Guess roles: platform_admin, group_admin, dealer_admin, ai_specialist,
//        sales_agent
//      Guess collections: grandfather_protocol/, stores/, system_config/,
//        ai_config/, chat_logs/, reflective_memory/, playground_sessions/,
//        media/, plus subcollections under users/{uid}/ for memory, settings,
//        personas, gallery, chat_sessions
//
// SHARED COLLECTIONS (both products write to these — rules combine):
//   * users/{uid}      — same documents, different role values
//   * groups/{id}      — Rally tenant root; Guess group_admin lookups
//   * vehicles/{id}    — Rally vehicles (dealershipId) + Guess vehicles (storeId)
//
// CONFLICT NOTE — vehicles/
// Rally vehicles use field `dealershipId`; Guess vehicles use `storeId`. Rules
// allow reads/writes via either path, scoped to the calling product's role
// system. There is residual cross-product visibility risk if a single user
// is provisioned in BOTH products with overlapping tenant ids — track this
// for future separation into distinct collections (e.g. rally_vehicles/).
//
// RALLY MODEL
// -----------
// Multi-tenant via custom claims set on the Firebase Auth token at user
// invite, role change, and tenant provisioning:
//   { groupId, dealershipId, role: <Rally role> }
// In legacy single-store mode, groupId == dealershipId == storeId. Rules
// fall back to a users/{uid} document lookup for tokens that pre-date the
// claim rollout.
//
// SUPER ADMINS (Rally)
// --------------------
// Two equivalent signals:
//   1. request.auth.token.superAdmin == true
//   2. uid in system/superAdmins.uids
//
// Run scripts/setup-super-admin.js <uid> to backfill the claim for an
// existing UID listed in SUPER_ADMIN_UIDS env var. Without backfilling,
// admin client-SDK reads will fail (admin route handlers bypass via
// firebase-admin so server paths still work).
//
// RALLY ROLE HIERARCHY (lower number == more authority):
//   0  owner
//   1  general_manager
//   2  sales_manager, service_manager, finance_manager
//   3  desk_manager
//   4  salesperson, bdc_agent, service_advisor
//   5  technician, porter, detailer, parts
//
// hasMinRole(level) returns true when the user's role hierarchy number is
// <= level. e.g. hasMinRole(3) == "desk_manager or higher".
//
// DENY BY DEFAULT
// ---------------
// The rule set ends with a wildcard deny so any collection not explicitly
// covered is locked down. Server SDK (firebase-admin) bypasses these rules,
// so route handlers that need to write privileged collections (auditLogs,
// system/, etc.) continue to work via the admin SDK.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================================================
    // SHARED HELPERS
    // ========================================================================

    function isSignedIn() {
      return request.auth != null;
    }

    // Alias used by the legacy Guess/WalletCard rules — kept verbatim so
    // those rule blocks don't need to be rewritten.
    function isAuthenticated() {
      return request.auth != null;
    }

    // ========================================================================
    // RALLY HELPERS
    // ========================================================================

    function isSuperAdmin() {
      return isSignedIn() && (
        (request.auth.token.superAdmin == true) ||
        (
          exists(/databases/$(database)/documents/system/superAdmins) &&
          request.auth.uid in get(/databases/$(database)/documents/system/superAdmins).data.uids
        )
      );
    }

    function userDocExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userTenantId() {
      return isSignedIn() ? (
        request.auth.token.dealershipId != null ? request.auth.token.dealershipId :
        (request.auth.token.groupId != null ? request.auth.token.groupId :
          (userDocExists() ? (
            userDoc().dealershipId != null ? userDoc().dealershipId : userDoc().groupId
          ) : null))
      ) : null;
    }

    function userGroupId() {
      return isSignedIn() ? (
        request.auth.token.groupId != null ? request.auth.token.groupId :
        (userDocExists() ? userDoc().groupId : null)
      ) : null;
    }

    function userStoreId() {
      return userTenantId();
    }

    function userRole() {
      return isSignedIn() ? (
        request.auth.token.role != null ? request.auth.token.role :
        (userDocExists() ? userDoc().role : null)
      ) : null;
    }

    function hasRole(role) {
      return userRole() == role;
    }

    function roleLevel(role) {
      return role == 'owner' ? 0
        : role == 'general_manager' ? 1
        : role == 'sales_manager' ? 2
        : role == 'service_manager' ? 2
        : role == 'finance_manager' ? 2
        : role == 'desk_manager' ? 3
        : role == 'salesperson' ? 4
        : role == 'bdc_agent' ? 4
        : role == 'service_advisor' ? 4
        : role == 'technician' ? 5
        : role == 'porter' ? 5
        : role == 'detailer' ? 5
        : role == 'parts' ? 5
        : 99;
    }

    function hasMinRole(level) {
      return isSignedIn() && roleLevel(userRole()) <= level;
    }

    function isManager()   { return hasMinRole(3); }
    function isSm()        { return hasMinRole(2); }
    function isGm()        { return hasMinRole(1); }
    function isOwner()     { return hasMinRole(0); }
    function isLineStaff() { return hasMinRole(5); }

    // Tenant scope check against a doc that carries dealershipId, storeId,
    // or groupId. Accepts any of the three names so Rally docs (dealershipId)
    // and per-group docs (groupId) both match the same caller.
    function inTenant(data) {
      return isSignedIn() && (
        (data.dealershipId != null && data.dealershipId == userTenantId()) ||
        (data.storeId      != null && data.storeId      == userStoreId())  ||
        (data.groupId      != null && data.groupId      == userGroupId())
      );
    }

    // ========================================================================
    // GUESS / WALLETCARD HELPERS  (verbatim from prior production rules)
    // ========================================================================

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isPlatformAdmin() {
      return isAuthenticated() && getUserData().role == 'platform_admin';
    }

    function isGroupAdmin(groupId) {
      let user = getUserData();
      return isAuthenticated() &&
             user.role == 'group_admin' &&
             user.groupId == groupId;
    }

    function isDealerAdmin(storeId) {
      let user = getUserData();
      return isAuthenticated() && (
        (user.role == 'dealer_admin' && user.storeId == storeId) ||
        (user.role == 'group_admin' && storeInGroup(storeId, user.groupId))
      );
    }

    function isAISpecialist(storeId) {
      let user = getUserData();
      return isAuthenticated() && (
        user.role == 'ai_specialist' && user.storeId == storeId
      );
    }

    function isSalesAgent(storeId) {
      let user = getUserData();
      return isAuthenticated() &&
             user.role == 'sales_agent' &&
             user.storeId == storeId;
    }

    function storeInGroup(storeId, groupId) {
      return get(/databases/$(database)/documents/stores/$(storeId)).data.groupId == groupId;
    }

    function hasStoreAccess(storeId, requiredLevel) {
      let user = getUserData();
      return isAuthenticated() && (
        isPlatformAdmin() ||
        (requiredLevel >= 2 && user.role == 'group_admin' && storeInGroup(storeId, user.groupId)) ||
        (requiredLevel >= 3 && user.role == 'dealer_admin' && user.storeId == storeId) ||
        (requiredLevel >= 4 && user.role == 'ai_specialist' && user.storeId == storeId) ||
        (requiredLevel >= 5 && user.role == 'sales_agent' && user.storeId == storeId)
      );
    }

    // ========================================================================
    // GUESS / WALLETCARD COLLECTION RULES (verbatim, except where noted)
    // ========================================================================

    // Open access for any authenticated user — pre-existing behavior.
    match /grandfather_protocol/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /stores/{storeId} {
      allow read: if isAuthenticated();
      allow write: if isPlatformAdmin();
      allow write: if isGroupAdmin(resource.data.groupId);
    }

    match /system_config/{configId} {
      allow read: if isAuthenticated();
      allow write: if isPlatformAdmin();
      allow write: if isGroupAdmin(resource.data.groupId);
    }

    match /system_config/global_prompts {
      allow read: if isAuthenticated();
      allow write: if isPlatformAdmin() || isGroupAdmin(resource.data.groupId);
    }

    match /ai_config/{configId} {
      allow read: if isAuthenticated();
      allow write: if isDealerAdmin(resource.data.storeId);
      allow write: if isAISpecialist(resource.data.storeId);
      allow create: if isDealerAdmin(request.resource.data.storeId) ||
                       isAISpecialist(request.resource.data.storeId);
    }

    match /chat_logs/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.agentId;
      allow read: if hasStoreAccess(resource.data.storeId, 3);
      allow create: if isAuthenticated();
      allow update: if (isAuthenticated() && request.auth.uid == resource.data.agentId) ||
                       hasStoreAccess(resource.data.storeId, 3);
      allow delete: if hasStoreAccess(resource.data.storeId, 3);

      match /sessions/{sessionId} {
         allow read, write: if isAuthenticated() && request.auth.uid == chatId;
         allow read: if resource.data.isShared == true;
      }
    }

    // User-owned subcollections (Guess-only — Rally does not write here).
    match /users/{userId}/memory/{memoryId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      allow read: if isPlatformAdmin();
    }
    match /users/{userId}/settings/{settingId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
    match /users/{userId}/personas/{personaId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
    match /users/{userId}/gallery/{assetId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      allow read: if isPlatformAdmin();
    }
    match /users/{userId}/chat_sessions/{sessionId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      match /messages/{messageId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    match /reflective_memory/{storeId}/embeddings/{embeddingId} {
      allow read: if hasStoreAccess(storeId, 5);
      allow write: if hasStoreAccess(storeId, 3);
    }

    match /playground_sessions/{sessionId} {
      allow read, write: if isDealerAdmin(resource.data.storeId) ||
                            isAISpecialist(resource.data.storeId);
      allow create: if isDealerAdmin(request.resource.data.storeId) ||
                       isAISpecialist(request.resource.data.storeId);
    }

    match /media/{userId}/{document=**} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      allow read: if isPlatformAdmin();
    }

    // ========================================================================
    // SHARED COLLECTIONS — combined Rally + Guess rules
    // ========================================================================

    // ------------------------------------------------------------------------
    // users/{uid}
    //
    // Combined access model. Multiple `allow` clauses OR together:
    //   * Self-read/write (both products)
    //   * Same-tenant read (Rally managers; Guess group_admin / dealer_admin)
    //   * Privileged write (Rally super_admin / GM; Guess platform_admin)
    // ------------------------------------------------------------------------
    match /users/{uid} {
      // ---- Reads ----
      // Self
      allow read: if isAuthenticated() && request.auth.uid == uid;
      // Rally super admin
      allow read: if isSuperAdmin();
      // Rally same-dealership/group reads (managers + line staff for attribution)
      allow read: if isSignedIn() && (
        (resource.data.dealershipId != null && resource.data.dealershipId == userTenantId()) ||
        (resource.data.groupId != null && resource.data.groupId == userGroupId())
      );
      // Guess platform_admin / group_admin / dealer_admin
      allow read: if isPlatformAdmin();
      allow read: if isGroupAdmin(resource.data.groupId);
      allow read: if isDealerAdmin(resource.data.storeId);

      // ---- Writes (create/update/delete) ----
      // Self create + self update (Guess pattern)
      allow create, update: if isAuthenticated() && request.auth.uid == uid;
      // Rally super admin can do anything
      allow create, update, delete: if isSuperAdmin();
      // Guess platform_admin write
      allow write: if isPlatformAdmin();
      // Rally self-update with affected-field allowlist
      allow update: if isSignedIn() && request.auth.uid == uid &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            'displayName', 'phone', 'photoURL', 'fcmTokens',
            'preferences', 'lastActiveAt', 'updatedAt'
          ]);
      // Rally GM updates within tenant (cannot move user across tenants)
      allow update: if isSignedIn() && isGm() &&
        resource.data.dealershipId == userTenantId() &&
        request.resource.data.dealershipId == resource.data.dealershipId &&
        request.resource.data.groupId == resource.data.groupId;
    }

    // ------------------------------------------------------------------------
    // groups/{groupId}
    //
    // Combined: Rally tenant root rules + Guess platform_admin write.
    // Tightening note: previously any authenticated user could read all
    // groups. Trey confirmed WalletCard does not rely on that — restricted
    // to same-group members (Rally model) and platform_admin (Guess).
    // ------------------------------------------------------------------------
    match /groups/{groupId} {
      // Read: super admin, same-group member (Rally), or platform_admin (Guess)
      allow read: if isSuperAdmin();
      allow read: if isSignedIn() && groupId == userGroupId();
      allow read: if isPlatformAdmin();

      // Write: super admin, owner of group (Rally), or platform_admin (Guess)
      allow create, update, delete: if isSuperAdmin();
      allow create, update, delete: if isSignedIn() && groupId == userGroupId() && isOwner();
      allow write: if isPlatformAdmin();

      // Rally subcollections (do not exist in Guess data model)
      match /stores/{storeId} {
        allow read: if isSuperAdmin() ||
          (isSignedIn() && groupId == userGroupId());
        allow create, update: if isSuperAdmin() ||
          (isSignedIn() && groupId == userGroupId() && isGm());
        allow delete: if isSuperAdmin() ||
          (isSignedIn() && groupId == userGroupId() && isOwner());
      }
      match /config/{configId} {
        allow read: if isSuperAdmin() ||
          (isSignedIn() && groupId == userGroupId() && isGm());
        allow write: if isSuperAdmin();
      }
      match /roles/{roleId} {
        allow read: if isSignedIn() && groupId == userGroupId();
        allow write: if isSuperAdmin() ||
          (isSignedIn() && groupId == userGroupId() && isGm());
      }
    }

    // ------------------------------------------------------------------------
    // vehicles/{vehicleId}
    //
    // Combined: Rally same-tenant rules + Guess hasStoreAccess + competitorx
    // server hydration.
    //
    // CHANGES vs prior production rules (per Trey's call — WalletCard does
    // not rely on these):
    //   - Removed `allow read: if true;`           (anonymous public read)
    //   - Removed `allow read: if isAuthenticated();` (any-auth, no scope)
    //
    // Reads now require either Rally same-tenant membership or Guess
    // hasStoreAccess at sales_agent level or higher.
    // ------------------------------------------------------------------------
    match /vehicles/{vehicleId} {
      // ---- Reads ----
      allow read: if isSuperAdmin();
      allow read: if isSignedIn() && inTenant(resource.data);
      allow read: if isAuthenticated() && hasStoreAccess(resource.data.storeId, 5);

      // ---- Server hydration (competitorx) ----
      allow create: if request.resource.data.source == 'competitorx-hydration';
      allow update: if resource.data.source == 'competitorx-hydration' ||
                       request.resource.data.source == 'competitorx-hydration';

      // ---- Rally writes ----
      allow create: if isSuperAdmin() ||
        (isLineStaff() && inTenant(request.resource.data));
      allow update: if isSuperAdmin() ||
        (isLineStaff() &&
          inTenant(resource.data) &&
          inTenant(request.resource.data) &&
          request.resource.data.dealershipId == resource.data.dealershipId);
      allow delete: if isSuperAdmin() ||
        (isSm() && inTenant(resource.data));

      // ---- Guess writes ----
      allow write:  if hasStoreAccess(resource.data.storeId, 3);
      allow create: if hasStoreAccess(request.resource.data.storeId, 3);
    }

    // ========================================================================
    // RALLY-ONLY COLLECTION RULES
    // ========================================================================

    match /dealerships/{dealershipId} {
      allow read: if isSuperAdmin() ||
        (isSignedIn() && dealershipId == userTenantId());
      allow create, update: if isSuperAdmin() ||
        (isSignedIn() && dealershipId == userTenantId() && isGm());
      allow delete: if isSuperAdmin();
    }

    match /employees/{uid} {
      allow read: if isSuperAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow update: if isSuperAdmin() || (
        isSignedIn() && request.auth.uid == uid &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['displayName', 'phone', 'photoURL', 'lastActiveAt', 'updatedAt'])
      );
      allow create, delete: if isSuperAdmin();

      match /memberships/{membershipId} {
        allow read: if isSuperAdmin() ||
          (isSignedIn() && request.auth.uid == uid) ||
          (isSignedIn() && isGm() && resource.data.groupId == userGroupId());
        allow write: if isSuperAdmin();
      }
    }

    match /vehicleLists/{listId} {
      allow read: if isSuperAdmin() || (
        isSignedIn() && inTenant(resource.data) && (
          resource.data.ownerId == request.auth.uid ||
          (resource.data.sharedWith is list &&
            request.auth.uid in resource.data.sharedWith) ||
          (resource.data.isShared == true)
        )
      );
      allow create: if isSuperAdmin() || (
        isSignedIn() &&
        request.resource.data.ownerId == request.auth.uid &&
        inTenant(request.resource.data)
      );
      allow update: if isSuperAdmin() || (
        isSignedIn() && inTenant(resource.data) && inTenant(request.resource.data) &&
        request.resource.data.dealershipId == resource.data.dealershipId &&
        (resource.data.ownerId == request.auth.uid || isSm())
      );
      allow delete: if isSuperAdmin() || (
        isSignedIn() && inTenant(resource.data) &&
        (resource.data.ownerId == request.auth.uid || isSm())
      );

      match /items/{itemId} {
        allow read: if isSuperAdmin() || (
          isSignedIn() &&
          exists(/databases/$(database)/documents/vehicleLists/$(listId)) &&
          (
            get(/databases/$(database)/documents/vehicleLists/$(listId)).data.ownerId == request.auth.uid ||
            (
              get(/databases/$(database)/documents/vehicleLists/$(listId)).data.sharedWith is list &&
              request.auth.uid in get(/databases/$(database)/documents/vehicleLists/$(listId)).data.sharedWith
            ) ||
            (
              get(/databases/$(database)/documents/vehicleLists/$(listId)).data.isShared == true &&
              get(/databases/$(database)/documents/vehicleLists/$(listId)).data.dealershipId == userTenantId()
            )
          )
        );
        allow write: if isSuperAdmin() || (
          isSignedIn() &&
          exists(/databases/$(database)/documents/vehicleLists/$(listId)) &&
          (
            get(/databases/$(database)/documents/vehicleLists/$(listId)).data.ownerId == request.auth.uid ||
            (
              get(/databases/$(database)/documents/vehicleLists/$(listId)).data.sharedWith is list &&
              request.auth.uid in get(/databases/$(database)/documents/vehicleLists/$(listId)).data.sharedWith
            )
          )
        );
      }
    }

    match /vehicleActivities/{activityId} {
      allow read: if isSuperAdmin() ||
        (isSignedIn() && inTenant(resource.data));
      allow create: if isSuperAdmin() || (
        isLineStaff() &&
        inTenant(request.resource.data) &&
        (
          !('userId' in request.resource.data.keys()) ||
          request.resource.data.userId == request.auth.uid
        )
      );
      allow update: if isSuperAdmin() || (
        isSignedIn() && inTenant(resource.data) && inTenant(request.resource.data) &&
        request.resource.data.dealershipId == resource.data.dealershipId &&
        (resource.data.userId == request.auth.uid || isSm())
      );
      allow delete: if isSuperAdmin() ||
        (isSm() && inTenant(resource.data));
    }

    match /nfcTags/{tagId} {
      allow read: if isSuperAdmin() ||
        (isSignedIn() && inTenant(resource.data));
      allow create, update: if isSuperAdmin() || (
        isLineStaff() &&
        inTenant(request.resource.data) &&
        (!('data' in resource) ||
          (inTenant(resource.data) &&
            request.resource.data.dealershipId == resource.data.dealershipId))
      );
      allow delete: if isSuperAdmin() ||
        (isSm() && inTenant(resource.data));
    }

    match /interactions/{interactionId} {
      allow read: if isSuperAdmin() ||
        (isSm() && inTenant(resource.data));
      allow create: if isSuperAdmin() || (
        isSignedIn() &&
        inTenant(request.resource.data) &&
        (
          !('userId' in request.resource.data.keys()) ||
          request.resource.data.userId == request.auth.uid
        )
      );
      allow update, delete: if false;
    }

    match /testDrives/{testDriveId} {
      allow read: if isSuperAdmin() ||
        (isSignedIn() && inTenant(resource.data));
      allow create: if isSuperAdmin() || (
        isLineStaff() &&
        inTenant(request.resource.data) &&
        (
          !('userId' in request.resource.data.keys()) ||
          request.resource.data.userId == request.auth.uid
        )
      );
      allow update: if isSuperAdmin() || (
        isSignedIn() && inTenant(resource.data) && inTenant(request.resource.data) &&
        request.resource.data.dealershipId == resource.data.dealershipId &&
        (resource.data.userId == request.auth.uid || isSm())
      );
      allow delete: if isSuperAdmin();
    }

    match /parkingSpaces/{spaceId} {
      allow read: if isSuperAdmin() ||
        (isSignedIn() && inTenant(resource.data));
      allow create, update: if isSuperAdmin() || (
        isLineStaff() &&
        inTenant(request.resource.data) &&
        (!('data' in resource) ||
          (inTenant(resource.data) &&
            request.resource.data.dealershipId == resource.data.dealershipId))
      );
      allow delete: if isSuperAdmin() ||
        (isSm() && inTenant(resource.data));
    }

    match /alerts/{alertId} {
      allow read: if isSuperAdmin() ||
        (isSignedIn() && inTenant(resource.data));
      allow create, update, delete: if isSuperAdmin() ||
        (isSm() && (
          (resource != null && inTenant(resource.data)) ||
          inTenant(request.resource.data)
        ));
    }

    match /crmCustomers/{id} {
      allow read: if isSuperAdmin() ||
        (isSignedIn() && inTenant(resource.data));
      allow create: if isSuperAdmin() || (
        isLineStaff() && inTenant(request.resource.data)
      );
      allow update: if isSuperAdmin() || (
        isLineStaff() &&
        inTenant(resource.data) && inTenant(request.resource.data) &&
        request.resource.data.dealershipId == resource.data.dealershipId
      );
      allow delete: if isSuperAdmin() ||
        (isSm() && inTenant(resource.data));
    }

    match /fleetVehicles/{id} {
      allow read: if isSuperAdmin() ||
        (isSignedIn() && inTenant(resource.data));
      allow write: if isSuperAdmin();
    }

    match /batteryReports/{id} {
      allow read: if isSuperAdmin() ||
        (isSignedIn() && inTenant(resource.data));
      allow write: if isSuperAdmin();
    }

    match /recentCrmViews/{uid} {
      allow read, write: if isSuperAdmin() ||
        (isSignedIn() && request.auth.uid == uid);
      match /customers/{docId} {
        allow read, write: if isSuperAdmin() ||
          (isSignedIn() && request.auth.uid == uid);
      }
      match /meta/{docId} {
        allow read, write: if isSuperAdmin() ||
          (isSignedIn() && request.auth.uid == uid);
      }
    }

    match /auditLogs/{logId} {
      allow read: if isSuperAdmin() || (
        isOwner() && resource.data.groupId != null &&
        resource.data.groupId == userGroupId()
      );
      allow write: if false;
    }

    match /aiUsage/{logId} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }

    match /featureFlags/{flagId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /system/{doc} {
      allow read, write: if isSuperAdmin();
    }

    // ========================================================================
    // Deny-by-default catch-all
    // Any collection not explicitly handled above is locked.
    // ========================================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
